{
  "info": {
    "name": "Pricing Platform API",
    "description": "Enterprise pricing engine API with dynamic quote calculations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["health"]
        },
        "description": "Check if the API is healthy and running"
      }
    },
    {
      "name": "Calculate Single Quote",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"basePrice\": 100,\n  \"weight\": 5.5,\n  \"location\": \"remote\",\n  \"destination\": \"International\",\n  \"requestTime\": \"2026-04-17T10:00:00Z\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/quotes/price",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["quotes", "price"]
        },
        "description": "Calculate a single quote with given parameters"
      }
    },
    {
      "name": "Submit Bulk Quote Request",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "[\n  {\n    \"basePrice\": 100,\n    \"weight\": 5.5,\n    \"location\": \"remote\",\n    \"destination\": \"International\",\n    \"requestTime\": \"2026-04-17T10:00:00Z\"\n  },\n  {\n    \"basePrice\": 200,\n    \"weight\": 2.0,\n    \"location\": \"local\",\n    \"destination\": \"Domestic\",\n    \"requestTime\": \"2026-04-17T10:00:00Z\"\n  }\n]"
        },
        "url": {
          "raw": "http://localhost:5000/quotes/bulk",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["quotes", "bulk"]
        },
        "description": "Submit multiple quotes for batch processing"
      }
    },
